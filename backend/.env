# backend/.env

# 应用配置
APP_NAME=书房管理系统
APP_VERSION=2.0.0
DEBUG=true
SECRET_KEY=change-me-to-a-random-key

# 服务器
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./bookshelf.db

